#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""董蜀黍的报纸 - 新闻采集脚本 v5 - 扩展分类"""

import requests, feedparser, time, logging, hashlib
from datetime import datetime
from bs4 import BeautifulSoup
from collections import defaultdict

def translate_text(text, source_lang='en', target_lang='zh-CN'):
    if not text or len(text.strip()) < 10:
        return ''
    
    en_chars = sum(1 for c in text if ord(c) < 128 and c.isalpha())
    total_alpha = sum(1 for c in text if c.isalpha())
    if total_alpha > 0 and en_chars / total_alpha < 0.3:
        return ''
    
    import urllib.request
    import urllib.parse
    import json
    import time
    
    segments = []
    chunk = ''
    for line in text.split('\n'):
        if len(chunk) + len(line) > 450:
            if chunk:
                segments.append(chunk)
            chunk = line
        else:
            chunk = chunk + '\n' + line if chunk else line
    if chunk:
        segments.append(chunk)
    
    translated = []
    for seg in segments:
        try:
            url = 'https://api.mymemory.translated.net/get?q=' + urllib.parse.quote(seg[:500]) + '&langpair=' + source_lang + '|' + target_lang
            req = urllib.request.Request(url)
            req.add_header('User-Agent', 'Mozilla/5.0')
            with urllib.request.urlopen(req, timeout=10) as resp:
                data = json.loads(resp.read().decode())
                translated.append(data.get('responseData', {}).get('translatedText', seg))
            time.sleep(0.5)
        except Exception as e:
            translated.append(seg)
    
    return '\n'.join(translated)


API_URL = "http://127.0.0.1:5000/api/articles"
LOG_FILE = "/var/www/dongshushu-paper/cron_collect.log"

RSS_SOURCES = {
    "36kr": {"url": "https://36kr.com/feed", "category": "科技头条", "source": "36氪"},
    "hackernews": {"url": "https://hnrss.org/frontpage", "category": "开发者生态", "source": "HackerNews"},
    "v2ex": {"url": "https://www.v2ex.com/index.xml", "category": "开发者生态", "source": "V2EX"},
}

FORBIDDEN = ["黄金", "娱乐", "明星", "股市", "彩票", "博彩", "赌博", "招聘", "求职", "岗位", "高薪", "诚聘", "招人", "内推", "社招", "校招"]

# 扩展分类关键词
CATEGORY_KEYWORDS = {
    "漏洞情报": ["漏洞", "CVE", "0day", "exploit", "补丁", "披露", "告警", "CVE-", "vulnerability"],
    "CTF安全": ["CTF", "ctf", "夺旗", "竞赛", "赛题", "writeup", "pwntools", "gdb-gef", "ROPgadget", "Steghide", "stego"],
    "网络安全": ["渗透", "攻击", "防护", "加密", "勒索", "恶意软件", "黑客", "入侵", "数据泄露", "APT", "钓鱼", "木馬", "ransomware", "phishing"],
    "智能AI": ["人工智能", "机器学习", "深度学习", "神经网络", "大模型", "LLM", "GPT", "Claude", "Gemini", "AI", "AI Agent", "AGI", "Sora", "ChatGPT"],
    "开源推荐": ["开源", "GitLab", "仓库", "项目", "框架", "开源项目"],
    "GitHub热门": ["GitHub", "github", "Trending", "stars", "repository"],
    "开发者生态": ["编程", "开发", "代码", "程序员", "IDE", "编译器", "API", "SDK"],
    "数码硬件": ["手机", "iPhone", "iPad", "Android", "芯片", "处理器", "CPU", "GPU", "Intel", "AMD", "NVIDIA", "高通", "苹果", "三星", "小米", "华为", "笔记本", "电脑"],
    "云计算": ["云", "K8s", "Docker", "容器", "Kubernetes", "AWS", "Azure", "GCP", "阿里云", "腾讯云", "DevOps", "Serverless"],
    "编程语言": ["Python", "Go", "Rust", "Java", "JavaScript", "TypeScript", "C++", "Ruby", "PHP", "Swift", "Kotlin", "Node.js"],
    "前端技术": ["前端", "CSS", "JavaScript", "React", "Vue", "Angular", "HTML", "DOM", "Webpack", "前端框架"],
    "数据库": ["MySQL", "Redis", "MongoDB", "PostgreSQL", "数据库", "SQL", "NoSQL", "Elasticsearch", "缓存"],
    "操作系统": ["Linux", "Ubuntu", "Windows", "macOS", "内核", "Android", "iOS", "kernel", "shell"],
    "时政热点": ["政治", "政府", "政策", "外交", "国际", "社会", "民生", "两会", "习近平", "拜登", "特朗普", "联合国", "G20"],
    "技术小贴士": ["教程", "技巧", "指南", "方法", "优化", "配置", "安装", "设置", "解决", "教程"],
    "科技头条": ["科技", "互联网", "创业", "融资", "IPO", "巨头", "BAT", "字节", "腾讯", "阿里", "百度"],
}

logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s',
    handlers=[logging.FileHandler(LOG_FILE, encoding='utf-8'), logging.StreamHandler()])
logger = logging.getLogger(__name__)

def is_forbidden(t, c=""):
    return any(k.lower() in (t+" "+c).lower() for k in FORBIDDEN)

def classify(t, c=""):
    """根据标题和内容自动分类"""
    txt = t + " " + c
    
    # 优先级最高：GitHub相关
    if any(k in txt.lower() for k in ["github", "trending", "repository"]):
        return "开源推荐"
    
    # 高优先级：安全相关
    if sum(2 for k in CATEGORY_KEYWORDS["CTF安全"] if k.lower() in txt.lower()) >= 2:
        return "CTF安全"
    if any(k in txt for k in ["CVE-", "漏洞", "0day", "exploit", "vulnerability"]):
        return "漏洞情报"
    if any(k.lower() in txt.lower() for k in ["渗透", "攻击", "勒索", "钓鱼", "入侵"]):
        return "网络安全"
    
    # 按关键词数量匹配
    sc = defaultdict(int)
    skip_cats = ["CTF安全", "漏洞情报", "网络安全", "开源推荐", "GitHub热门"]
    
    for cat, kws in CATEGORY_KEYWORDS.items():
        if cat in skip_cats:
            continue
        for kw in kws:
            if kw.lower() in txt.lower():
                sc[cat] += 1
    
    # 返回得分最高的分类
    if sc:
        best_cat = max(sc, key=sc.get)
        if sc[best_cat] >= 2:  # 至少2个关键词匹配
            return best_cat
    
    return "科技头条"  # 默认分类

def clean(h):
    if not h: return ""
    return ' '.join(BeautifulSoup(h, 'lxml').get_text(separator=' ', strip=True).split())

def gen_content(t):
    import random
    return random.choice([f"本文报道了关于{t}的最新动态。", f"{t}是近期热门话题。", f"关于{t}的报道引起了业界关注。"])

def fetch_rss(name, cfg):
    arts = []
    try:
        r = requests.get(cfg["url"], headers={"User-Agent":"Mozilla/5.0"}, timeout=15)
        r.raise_for_status()
        feed = feedparser.parse(r.content)
        logger.info(f"从 {name} 获取 {len(feed.entries)} 条")
        for e in feed.entries[:10]:
            try:
                t = clean(e.get("title",""))
                if not t or len(t) < 5: continue
                con = clean(e.get("summary", e.get("description", "")))
                if len(con) < 50: con = gen_content(t)
                if is_forbidden(t, con): continue
                cat = classify(t, con)
                src = cfg.get("source") or name
                arts.append({"title":t[:200], "content":con[:2000], "category":cat, "source":src,
                    "date":datetime.now().strftime("%Y-%m-%d"), "is_published":True,
                    "_id":hashlib.md5(t.encode()).hexdigest()[:16]})
            except: continue
    except Exception as e:
        logger.error(f"抓取 {name} 失败: {e}")
    return arts

def fetch_github():
    arts = []
    try:
        r = requests.get("https://api.github.com/search/repositories?q=created:>2024-01-01&sort=stars&order=desc&per_page=5",
                       headers={"User-Agent":"Mozilla/5.0","Accept":"application/vnd.github.v3+json"}, timeout=15)
        if r.status_code == 200:
            for repo in r.json().get("items", [])[:5]:
                t = repo['name']  # 去掉分类前缀
                desc = repo.get('description', '') or repo.get('name', '')
                lang = repo.get('language', '')
                forks = repo.get('forks_count', 0)
                lic = repo.get('license', {})
                lic_name = lic.get('spdx_id', '') if lic else ''
                html_url = repo.get('html_url', '')
                c_parts = [desc]
                if repo['stargazers_count']: c_parts.append("⭐ Stars: {:,}".format(repo['stargazers_count']))
                if lang: c_parts.append("语言: " + lang)
                if forks: c_parts.append("Forks: {:,}".format(forks))
                if lic_name: c_parts.append("许可证: " + lic_name)
                if html_url: c_parts.append("项目地址: " + html_url)
                c = "\n\n".join(c_parts)
                if not is_forbidden(t, c):
                    # GitHub项目自动分类
                    cat = classify(t + " " + desc, desc)
                    arts.append({"title":t[:200], "content":c[:2000], "category":cat, "source":"GitHub Trending",
                        "date":datetime.now().strftime("%Y-%m-%d"), "is_published":True,
                        "_id":hashlib.md5(t.encode()).hexdigest()[:16]})
    except Exception as e:
        logger.error(f"GitHub采集失败: {e}")
    return arts

def push(arts, pt="morning"):
    if not arts: return 0
    sc = 0
    for a in arts:
        a["paper_type"] = pt
        if "content_cn" not in a or not a["content_cn"]:
            try:
                tc = translate_text(a.get("content", ""))
                if tc: a["content_cn"] = tc
            except: pass
        try:
            r = requests.post(API_URL, json=a, headers={"Content-Type":"application/json"}, timeout=10)
            if r.status_code in [200,201]: sc += 1
        except: logger.error("推送失败")
        time.sleep(0.5)
    return sc

def collect(pt="morning"):
    logger.info(f"=== 开始采集 [{pt}] ===")
    all_a, seen = [], set()
    for n, cfg in RSS_SOURCES.items():
        for a in fetch_rss(n, cfg):
            if a["_id"] not in seen: seen.add(a["_id"]); all_a.append(a)
        time.sleep(1)
    for a in fetch_github():
        if a["_id"] not in seen: seen.add(a["_id"]); all_a.append(a)
    logger.info(f"共 {len(all_a)} 篇")
    sc = push(all_a, pt)
    logger.info(f"=== 完成，成功 {sc} 篇 ===")
    return sc

if __name__ == "__main__":
    import sys
    pt = "morning"
    if len(sys.argv) > 1: pt = sys.argv[1] if sys.argv[1] in ["morning","evening"] else ("evening" if datetime.now().hour >= 12 else "morning")
    logger.info(f"采集脚本启动 - {pt}")
    try:
        sys.exit(0 if collect(pt) > 0 else 1)
    except Exception as e:
        logger.error(f"异常: {e}")
        sys.exit(1)
