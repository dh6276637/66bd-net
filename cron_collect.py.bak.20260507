#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""66必读 - 新闻采集脚本 v7 - 添加自动翻译和清理标题"""

import requests, feedparser, time, logging, hashlib, re
from datetime import datetime
from bs4 import BeautifulSoup
from collections import defaultdict

def translate_text(text, source_lang='en', target_lang='zh-CN'):
    """翻译文本内容"""
    if not text or len(text.strip()) < 10: return ''
    en_chars = sum(1 for c in text if ord(c) < 128 and c.isalpha())
    total_alpha = sum(1 for c in text if c.isalpha())
    if total_alpha > 0 and en_chars / total_alpha < 0.3: return ''
    import urllib.request, urllib.parse, json
    segments, chunk = [], ''
    for line in text.split('\n'):
        if len(chunk) + len(line) > 450:
            if chunk: segments.append(chunk)
            chunk = line
        else: chunk = chunk + '\n' + line if chunk else line
    if chunk: segments.append(chunk)
    translated = []
    for seg in segments:
        try:
            url = 'https://api.mymemory.translated.net/get?q=' + urllib.parse.quote(seg[:500]) + '&langpair=' + source_lang + '|' + target_lang
            req = urllib.request.Request(url)
            req.add_header('User-Agent', 'Mozilla/5.0')
            with urllib.request.urlopen(req, timeout=10) as resp:
                data = json.loads(resp.read().decode())
                translated.append(data.get('responseData', {}).get('translatedText', seg))
            time.sleep(0.5)
        except: translated.append(seg)
    return '\n'.join(translated)

def translate_title(title):
    """翻译标题，只翻译英文标题返回中文"""
    if not title or len(title.strip()) < 3: return ''
    # 判断是否主要是英文
    en_chars = sum(1 for c in title if ord(c) < 128 and c.isalpha())
    total_alpha = sum(1 for c in title if c.isalpha())
    if total_alpha > 0 and en_chars / total_alpha < 0.5: return ''
    try:
        import urllib.request, urllib.parse, json
        url = 'https://translate.googleapis.com/translate_a/single?client=gtx&sl=en&tl=zh-CN&dt=t&q=' + urllib.parse.quote(title[:200])
        req = urllib.request.Request(url)
        req.add_header('User-Agent', 'Mozilla/5.0')
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read().decode())
            if data and data[0]:
                return ''.join(item[0] for item in data[0] if item[0])
    except: pass
    return ''

API_URL = "http://127.0.0.1:5000/api/articles"
LOG_FILE = "/var/www/dongshushu-paper/cron_collect.log"

RSS_SOURCES = {
    "36kr": {"url": "https://36kr.com/feed", "category": "科技头条", "source": "36氪"},
    "hackernews": {"url": "https://hnrss.org/frontpage", "category": "开发者生态", "source": "HackerNews"},
    "xinhua": {"url": "http://www.news.cn/rss/news.xml", "category": "时政热点", "source": "新华网"},
    "people": {"url": "http://paper.people.com.cn/rss/rss.aspx?type=gnxw", "category": "时政热点", "source": "人民网"},
}

FORBIDDEN = ["黄金", "娱乐", "明星", "股市", "彩票", "博彩", "赌博", "招聘", "求职", "高薪", "诚聘",
    "问与答", "分享发现", "分享创造", "强迫症", "海淘", "推广", "AI中转", "论坛", "闲聊", "求助", "水帖"]

CATEGORY_KEYWORDS = {
    "漏洞情报": ["漏洞", "CVE", "0day", "exploit", "补丁", "披露", "告警", "CVE-", "vulnerability"],
    "CTF安全": ["CTF", "夺旗", "竞赛", "赛题", "writeup"],
    "网络安全": ["渗透", "攻击", "防护", "加密", "勒索", "恶意软件", "黑客", "入侵", "数据泄露", "APT", "钓鱼"],
    "智能AI": ["人工智能", "机器学习", "深度学习", "神经网络", "大模型", "LLM", "GPT", "Claude", "AI", "AI Agent", "AGI", "Sora", "ChatGPT", "Codex"],
    "开源推荐": ["开源", "GitLab", "仓库", "项目", "框架"],
    "GitHub热门": ["GitHub", "github", "Trending", "stars", "repository"],
    "开发者生态": ["编程", "开发", "代码", "程序员", "IDE", "编译器", "API", "SDK"],
    "时政热点": ["政治", "政府", "政策", "外交", "国际", "社会", "民生", "两会", "中国", "美国", "俄罗斯", "欧洲", "经济", "贸易"],
    "技术小贴士": ["教程", "技巧", "指南", "方法", "优化", "配置", "安装", "设置", "解决"],
    "科技头条": ["科技", "互联网", "创业", "融资", "IPO", "巨头", "字节", "腾讯", "阿里", "百度"],
}

logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s',
    handlers=[logging.FileHandler(LOG_FILE, encoding='utf-8'), logging.StreamHandler()])
logger = logging.getLogger(__name__)

def is_forbidden(t, c=""):
    txt = (t + " " + c).lower()
    for k in FORBIDDEN:
        if k.lower() in txt: return True
    return False

def is_low_quality(t, c=""):
    if '?' in t and len(t) < 50: return True
    if len(c) < 100: return True
    return False

def clean(h):
    if not h: return ""
    return ' '.join(BeautifulSoup(h, 'lxml').get_text(separator=' ', strip=True).split())

def classify(t, c=""):
    txt = t + " " + c
    if any(k in txt.lower() for k in ["github", "trending", "repository"]): return "开源推荐"
    if sum(2 for k in CATEGORY_KEYWORDS["CTF安全"] if k.lower() in txt.lower()) >= 2: return "CTF安全"
    if any(k in txt for k in ["CVE-", "漏洞", "0day", "exploit", "vulnerability"]): return "漏洞情报"
    if any(k.lower() in txt.lower() for k in ["渗透", "攻击", "勒索", "钓鱼", "入侵"]): return "网络安全"
    if any(k in txt for k in ["政治", "政府", "政策", "外交", "中国", "美国", "俄罗斯"]): return "时政热点"
    sc = defaultdict(int)
    for cat, kws in CATEGORY_KEYWORDS.items():
        if cat in ["CTF安全", "漏洞情报", "网络安全", "开源推荐", "GitHub热门"]: continue
        for kw in kws:
            if kw.lower() in txt.lower(): sc[cat] += 1
    if sc:
        best_cat = max(sc, key=sc.get)
        if sc[best_cat] >= 2: return best_cat
    return "科技头条"

def fetch_rss(name, cfg):
    arts = []
    try:
        r = requests.get(cfg["url"], headers={"User-Agent":"Mozilla/5.0"}, timeout=15)
        r.raise_for_status()
        feed = feedparser.parse(r.content)
        logger.info(f"从 {name} 获取 {len(feed.entries)} 条")
        for e in feed.entries[:10]:
            try:
                t = clean(e.get("title",""))
                if not t or len(t) < 5: continue
                con = clean(e.get("summary", e.get("description", "")))
                if is_forbidden(t, con): continue
                if is_low_quality(t, con): continue
                if len(con) < 50: continue
                cat = classify(t, con)
                src = cfg.get("source") or name
                
                # 为HackerNews生成中文标题
                title_cn = None
                if src == "HackerNews":
                    translated = translate_title(t)
                    if translated:
                        title_cn = "【科技资讯】" + translated
                        time.sleep(1)  # 避免API限制
                
                article = {"title":t[:200], "content":con[:2000], "category":cat, "source":src,
                    "date":datetime.now().strftime("%Y-%m-%d"), "is_published":True,
                    "_id":hashlib.md5(t.encode()).hexdigest()[:16]}
                if title_cn:
                    article["title_cn"] = title_cn
                arts.append(article)
            except: continue
    except Exception as e:
        logger.error(f"抓取 {name} 失败: {e}")
    return arts

def fetch_github():
    arts = []
    try:
        r = requests.get("https://api.github.com/search/repositories?q=created:>2024-01-01&sort=stars&order=desc&per_page=5",
                       headers={"User-Agent":"Mozilla/5.0","Accept":"application/vnd.github.v3+json"}, timeout=15)
        if r.status_code == 200:
            for repo in r.json().get("items", [])[:5]:
                t = repo['name']
                desc = repo.get('description', '') or repo.get('name', '')
                if not desc or desc == repo['name']: desc = "暂无项目描述"
                lang = repo.get('language', '')
                forks = repo.get('forks_count', 0)
                stars = repo.get('stargazers_count', 0)
                lic = repo.get('license', {})
                lic_name = lic.get('spdx_id', '') if lic else ''
                html_url = repo.get('html_url', '')
                
                # 构建content，包含Stars等信息
                c_parts = [f"项目说明: {desc}"]
                if stars: c_parts.append("⭐ Stars: {:,}".format(stars))
                if lang: c_parts.append("语言: " + lang)
                if forks: c_parts.append("Forks: {:,}".format(forks))
                if lic_name: c_parts.append("许可证: " + lic_name)
                if html_url: c_parts.append("项目地址: " + html_url)
                c = "\n\n".join([x for x in c_parts if x])
                
                if not is_forbidden(t, c):
                    cat = classify(t + " " + desc, desc)
                    # 生成干净的title_cn，只包含项目名和描述
                    title_cn = "【开源项目】" + t
                    if desc and desc != "暂无项目描述":
                        title_cn = title_cn + " - " + desc
                    
                    arts.append({"title":t[:200], "title_cn":title_cn[:300], "content":c[:2000], "category":cat, "source":"GitHub Trending",
                        "date":datetime.now().strftime("%Y-%m-%d"), "is_published":True,
                        "_id":hashlib.md5(t.encode()).hexdigest()[:16]})
    except Exception as e:
        logger.error(f"GitHub采集失败: {e}")
    return arts

def push(arts, pt="morning"):
    if not arts: return 0
    sc = 0
    for a in arts:
        a["paper_type"] = pt
        try:
            r = requests.post(API_URL, json=a, headers={"Content-Type":"application/json"}, timeout=10)
            if r.status_code in [200,201]: sc += 1
        except: logger.error("推送失败")
        time.sleep(0.5)
    return sc

def collect(pt="morning"):
    logger.info(f"=== 开始采集 [{pt}] ===")
    all_a, seen = [], set()
    for n, cfg in RSS_SOURCES.items():
        for a in fetch_rss(n, cfg):
            if a["_id"] not in seen: seen.add(a["_id"]); all_a.append(a)
        time.sleep(1)
    for a in fetch_github():
        if a["_id"] not in seen: seen.add(a["_id"]); all_a.append(a)
    logger.info(f"共 {len(all_a)} 篇")
    sc = push(all_a, pt)
    logger.info(f"=== 完成，成功 {sc} 篇 ===")
    return sc

if __name__ == "__main__":
    import sys
    pt = "morning"
    if len(sys.argv) > 1: pt = sys.argv[1] if sys.argv[1] in ["morning","evening"] else ("evening" if datetime.now().hour >= 12 else "morning")
    logger.info(f"采集脚本启动 - {pt}")
    try:
        sys.exit(0 if collect(pt) > 0 else 1)
    except Exception as e:
        logger.error(f"异常: {e}")
        sys.exit(1)
