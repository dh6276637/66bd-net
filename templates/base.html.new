<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="index, follow">
    <meta name="applicable-device" content="pc,mobile">
    <title>{% block title %}{% if seo and seo.title %}{{ seo.title }}{% else %}66必读{% endif %}{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Source+Code+Pro:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root { --wired-black: #000; --wired-white: #fff; --wired-gray: #666; --wired-light: #f5f5f5; --wired-font-serif: 'Playfair Display', Georgia, serif; --wired-font-mono: 'Source Code Pro', monospace; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: var(--wired-font-serif); background: var(--wired-white); color: var(--wired-black); line-height: 1.6; max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        a { color: inherit; text-decoration: none; }
        a:hover { text-decoration: underline; }
        header { border-bottom: 1px solid var(--wired-black); padding: 20px 0; margin-bottom: 30px; }
        .header-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .logo { font-size: 2.5em; font-weight: 700; letter-spacing: -1px; }
        nav ul { list-style: none; display: flex; gap: 20px; flex-wrap: wrap; }
        nav ul li a { font-family: var(--wired-font-mono); font-size: 0.8em; text-transform: uppercase; }
        nav ul li a:hover { text-decoration: none; border-bottom: 2px solid var(--wired-black); }
        .user-nav { display: flex; gap: 10px; align-items: center; }
        .user-nav a { font-family: var(--wired-font-mono); font-size: 0.75em; padding: 5px 12px; border: 1px solid var(--wired-black); }
        .user-nav a:hover { background: var(--wired-black); color: var(--wired-white); }
        main { min-height: 60vh; }
        footer { border-top: 1px solid var(--wired-black); padding: 30px 0; margin-top: 50px; }
        .footer-links { font-family: var(--wired-font-mono); font-size: 0.75em; }
        .article-meta { font-family: var(--wired-font-mono); font-size: 0.7em; color: var(--wired-gray); }
        .source-tag { display: inline-block; font-size: 0.65em; padding: 2px 6px; background: #f0f0f0; color: var(--wired-gray); border-radius: 3px; margin-right: 8px; }
        .favorite-btn { cursor: pointer; color: var(--wired-gray); transition: color 0.2s; }
        .favorite-btn:hover, .favorite-btn.active { color: #ff4444; }
        .page-header { border-bottom: 1px solid var(--wired-black); padding-bottom: 15px; margin-bottom: 30px; }
        .page-header h1 { font-size: 2em; font-weight: 700; }
        .category-nav-scroll { overflow-x: auto; white-space: nowrap; padding: 10px 0; margin-bottom: 20px; -webkit-overflow-scrolling: touch; }
        .category-nav-scroll::-webkit-scrollbar { height: 4px; }
        .category-nav-scroll::-webkit-scrollbar-thumb { background: #ccc; border-radius: 2px; }
        .category-nav-inner { display: inline-flex; gap: 8px; }
        .category-tag { font-family: var(--wired-font-mono); font-size: 0.7em; padding: 5px 12px; background: var(--wired-light); color: var(--wired-gray); border-radius: 15px; white-space: nowrap; }
        .category-tag:hover, .category-tag.active { background: var(--wired-black); color: var(--wired-white); text-decoration: none; }
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; }
        .modal.show { display: flex; align-items: center; justify-content: center; }
        .modal-content { background: white; padding: 30px; max-width: 400px; width: 90%; border-radius: 5px; }
        .modal h2 { margin-bottom: 20px; font-size: 1.5em; }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; font-family: var(--wired-font-mono); font-size: 0.8em; }
        .form-group input { width: 100%; padding: 10px; border: 1px solid #ccc; font-size: 1em; }
        .form-group button { width: 100%; padding: 12px; background: var(--wired-black); color: white; border: none; cursor: pointer; font-family: var(--wired-font-mono); font-size: 0.9em; }
        .form-group button:hover { background: #333; }
        .form-switch { text-align: center; margin-top: 15px; font-family: var(--wired-font-mono); font-size: 0.8em; }
        .form-switch a { color: var(--wired-black); text-decoration: underline; }
        .close-modal { float: right; cursor: pointer; font-size: 1.5em; }
        @media (max-width: 768px) { .header-top { flex-direction: column; align-items: flex-start; } .logo { font-size: 1.8em; } }
    </style>
    {% block extra_head %}{% endblock %}
</head>
<body>
    <header>
        <div class="header-top">
            <div class="logo"><a href="/">66必读</a></div>
            <div class="user-nav">
                {% if user_id %}
                <a href="/user/profile">{{ session.get('username') }}</a>
                <a href="/user/favorites">收藏</a>
                <a href="#" onclick="logout(); return false;">退出</a>
                {% else %}
                <a href="#" onclick="showLogin(); return false;">登录</a>
                <a href="#" onclick="showRegister(); return false;">注册</a>
                {% endif %}
            </div>
        </div>
        <nav>
            <ul>
                <li><a href="/">首页</a></li>
                <li><a href="/paper">报纸</a></li>
                <li><a href="/messages">留言板</a></li>
                <li><a href="/about">关于</a></li>
            </ul>
        </nav>
    </header>
    <main>{% block content %}{% endblock %}</main>
    <footer>
        <div class="footer-content">
            <div class="footer-links"><a href="/">首页</a><a href="/paper">报纸</a><a href="/messages">留言板</a><a href="/about">关于</a><a href="/rss.xml">RSS</a></div>
            <span style="font-family: var(--wired-font-mono); font-size: 0.7em; color: var(--wired-gray);">&copy; 2024</span>
        </div>
    </footer>
    <div id="loginModal" class="modal"><div class="modal-content"><span class="close-modal" onclick="closeModal('loginModal')">&times;</span><h2>登录</h2><form onsubmit="handleLogin(event)"><div class="form-group"><label>用户名或邮箱</label><input type="text" name="username" required></div><div class="form-group"><label>密码</label><input type="password" name="password" required></div><div class="form-group"><button type="submit">登录</button></div><div class="form-switch">还没有账号？<a href="#" onclick="switchModal('loginModal', 'registerModal'); return false;">立即注册</a></div></form></div></div>
    <div id="registerModal" class="modal"><div class="modal-content"><span class="close-modal" onclick="closeModal('registerModal')">&times;</span><h2>注册</h2><form onsubmit="handleRegister(event)"><div class="form-group"><label>用户名</label><input type="text" name="username" required minlength="2" maxlength="30"></div><div class="form-group"><label>邮箱</label><input type="email" name="email" required></div><div class="form-group"><label>密码</label><input type="password" name="password" required minlength="6"></div><div class="form-group"><button type="submit">注册</button></div><div class="form-switch">已有账号？<a href="#" onclick="switchModal('registerModal', 'loginModal'); return false;">立即登录</a></div></form></div></div>
    <script>
    function showLogin(){document.getElementById('loginModal').classList.add('show');}
    function showRegister(){document.getElementById('registerModal').classList.add('show');}
    function closeModal(id){document.getElementById(id).classList.remove('show');}
    function switchModal(from,to){closeModal(from);document.getElementById(to).classList.add('show');}
    async function handleLogin(e){e.preventDefault();const f=e.target,d={username:f.username.value,password:f.password.value};try{const r=await fetch('/api/auth/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(d)}),j=await r.json();if(j.success)location.reload();else alert(j.error);}catch(err){alert('登录失败');}}
    async function handleRegister(e){e.preventDefault();const f=e.target,d={username:f.username.value,email:f.email.value,password:f.password.value};try{const r=await fetch('/api/auth/register',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(d)}),j=await r.json();if(j.success)location.reload();else alert(j.error);}catch(err){alert('注册失败');}}
    async function logout(){await fetch('/api/auth/logout',{method:'POST'});location.reload();}
    async function toggleFavorite(id,btn){try{const r=await fetch('/api/favorites',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({article_id:id})}),j=await r.json();if(j.need_login){showLogin();return;}if(j.success){btn.classList.toggle('active');const c=btn.querySelector('.count');if(c)c.textContent=j.favorite_count;}}catch(err){}}
    </script>
    <script>(function(){var sid=localStorage.getItem('ds_s')||'s_'+Date.now()+'_'+Math.random().toString(36).substr(2,9);localStorage.setItem('ds_s',sid);var vid=null,start=Date.now();fetch('/api/track',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({path:location.pathname,session_id:sid})}).then(r=>r.json()).then(d=>{vid=d.view_id;setInterval(function(){if(vid)fetch('/api/track/heartbeat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({view_id:vid,dwell_time:Math.round((Date.now()-start)/1000)})}).catch(function(){})},30000);}).catch(function(){});})();</script>
    {% block extra_scripts %}{% endblock %}
</body>
</html>
